# Base de datos PostgreSQL
DATABASE_URL="postgresql://user:password@localhost:5432/coldcall?schema=public"

# JWT para sesiones (cambiar en producción)
JWT_SECRET="change-me-to-a-long-random-string-in-production"

# URL base de la app (para emails, Stripe, etc.)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Stripe (producción)
# Clave secreta: Dashboard Stripe → Developers → API keys
# STRIPE_SECRET_KEY="sk_live_..."
# IDs de precio (Price ID) de cada plan: Dashboard → Products → crear productos y precios
# STRIPE_PRICE_GROWTH="price_..."   # plan Crecimiento 40€/mes
# STRIPE_PRICE_UNLIMITED="price_..." # plan Pro ilimitado 60€/mes
# Webhook: configurar en Stripe la URL https://tu-dominio.com/api/billing/webhook y evento checkout.session.completed
# STRIPE_WEBHOOK_SECRET="whsec_..."

# SMTP para envío de emails (opcional en desarrollo)
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_USER="user"
# SMTP_PASS="password"
# FROM_EMAIL="no-reply@coldcall-trainer.local"
