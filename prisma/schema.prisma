// ColdCall Trainer - Schema de base de datos
// PostgreSQL + Prisma ORM

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String    @map("password_hash")
  role          String    @default("free") // legacy: free | pro
  /// Plan de suscripción: free | professional | premium
  plan          String    @default("free")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  callSessions        CallSession[]
  userSettings        UserSettings?
  passwordResetTokens PasswordResetToken[]
  customScenarios     CustomScenario[]
  /// Membresías en equipos
  teamMemberships     TeamMember[]
  /// Equipos creados/administrados por este usuario
  ownedTeams          Team[]
}

/// Un equipo de ventas. El owner es quien lo creó (manager principal).
/// Un usuario con plan premium puede tener varios equipos.
model Team {
  id          String   @id @default(cuid())
  name        String
  ownerId     String   @map("owner_id")
  owner       User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  /// Plan del equipo: professional (1 equipo, 10 asientos) | premium (ilimitado)
  plan        String   @default("professional")
  maxSeats    Int      @default(10) @map("max_seats")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  members         TeamMember[]
  teamScenarios   TeamScenario[]

  @@map("teams")
}

/// Miembro de un equipo. Roles: manager | member
model TeamMember {
  id        String   @id @default(cuid())
  teamId    String   @map("team_id")
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// manager: puede ver todas las llamadas del equipo, gestionar miembros y crear escenarios
  /// member: acceso según permisos individuales
  teamRole  String   @default("member") @map("team_role")
  /// Permisos individuales del miembro
  canCreateScenarios  Boolean @default(false) @map("can_create_scenarios")
  canViewTeamCalls    Boolean @default(false) @map("can_view_team_calls")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([teamId, userId])
  @@map("team_members")
}

/// Escenario personalizado asociado a un equipo (visible para todos sus miembros)
model TeamScenario {
  id              String   @id @default(cuid())
  teamId          String   @map("team_id")
  team            Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  /// Usuario que lo creó (debe ser manager)
  createdById     String   @map("created_by_id")
  name            String
  prospectName    String   @map("prospect_name")
  industry        String
  product         String
  callGoal        String   @map("call_goal")
  prospectType    String   @map("prospect_type")
  personality     String
  context         String   @db.Text
  objections      String   @db.Text
  constraints     String?  @db.Text
  difficulty      String   @default("normal")
  locale          String   @default("es-ES")
  tone            String   @default("formal")
  generatedPrompt String   @map("generated_prompt") @db.Text
  prepNotes       String?  @map("prep_notes") @db.Text
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("team_scenarios")
}

model UserSettings {
  id              String   @id @default(cuid())
  userId          String   @unique @map("user_id")
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  industry        String?  @default("general")
  defaultDifficulty String @default("normal") @map("default_difficulty")
  defaultProspectType String? @map("default_prospect_type")
  defaultPersonality String? @map("default_personality")
  aiProvider      String?  @map("ai_provider")
  aiSystemPrompt  String?  @map("ai_system_prompt")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
}

model CallSession {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mode            String
  industry        String?
  difficulty      String
  prospectType    String?  @map("prospect_type")
  personality     String?
  durationSeconds Int?     @map("duration_seconds")
  startedAt      DateTime @default(now()) @map("started_at")
  endedAt        DateTime? @map("ended_at")

  transcriptEntries TranscriptEntry[]
  scoreResult       ScoreResult?
}

model TranscriptEntry {
  id          String   @id @default(cuid())
  sessionId   String   @map("session_id")
  session     CallSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  speaker     String
  text        String   @db.Text
  startMs     Int?     @map("start_ms")
  endMs       Int?     @map("end_ms")
  createdAt   DateTime @default(now()) @map("created_at")
}

model ScoreResult {
  id                String   @id @default(cuid())
  sessionId         String   @unique @map("session_id")
  session           CallSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  totalScore        Int      @map("total_score")
  objectionHandling Int?     @map("objection_handling")
  questionQuality   Int?     @map("question_quality")
  conversationControl Int?   @map("conversation_control")
  talkListenRatio   Float?   @map("talk_listen_ratio")
  confidence        Int?
  persistence       Int?
  spinUsage         Int?     @map("spin_usage")
  tonalityProxy     Int?     @map("tonality_proxy")
  breakdownJson     String?  @map("breakdown_json") @db.Text
  suggestionsJson   String?  @map("suggestions_json") @db.Text
  weakResponsesJson String?  @map("weak_responses_json") @db.Text
  expertAnalysis    String?  @map("expert_analysis") @db.Text
  createdAt         DateTime @default(now()) @map("created_at")
}

model CustomScenario {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String
  prospectName    String   @map("prospect_name")
  industry        String
  product         String
  callGoal        String   @map("call_goal")
  prospectType    String   @map("prospect_type")
  personality     String
  context         String   @db.Text
  objections      String   @db.Text
  constraints     String?  @db.Text
  difficulty      String   @default("normal")
  locale          String   @default("es-ES")
  tone            String   @default("formal")
  generatedPrompt String   @map("generated_prompt") @db.Text
  prepNotes       String?  @map("prep_notes") @db.Text
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("custom_scenarios")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime @default(now()) @map("created_at")
}
